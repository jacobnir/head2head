# Copy this file to `.env` and paste your key in.
#
# Get one at https://developer.riotgames.com — sign in with your Riot account and a
# DEVELOPMENT KEY is shown on the dashboard immediately. It's free.
#
# ⚠ Development keys EXPIRE EVERY 24 HOURS. That's fine: you only need a valid key when
#   you run `npm run sync-stats`, never when you actually run the app. Grab a fresh one
#   and re-paste it whenever you want to refresh everyone's stats.
#
# (If this becomes annoying, apply for a Personal API Key on the same site — it doesn't
#  expire, but approval takes a few days.)

RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
